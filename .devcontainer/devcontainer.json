{
  "name": "MariaDB Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "mounts": [
    {
      "type": "bind",
      "source": "${containerWorkspaceFolder}/.db-data",
      "target": "/var/lib/mysql"
    }
  ],
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [3306]
}
